{
  "$id": "https://tcrn.dev/schemas/conference-minutes-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCRN Conference Minutes V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "conferenceId",
    "projectId",
    "summary",
    "outcomeClass",
    "decisions",
    "unresolvedIssues",
    "revision",
    "updatedAt",
    "tombstone",
    "extensions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.conference.v1.minutes"
    },
    "id": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "conferenceId": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "projectId": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "x-tcrn-maxUtf8Bytes": 2048
    },
    "outcomeClass": {
      "enum": [
        "discussion_only",
        "recommendation",
        "role_decision",
        "blocked",
        "owner_intent_required"
      ]
    },
    "decisions": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "x-tcrn-maxUtf8Bytes": 2048
      }
    },
    "unresolvedIssues": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048,
        "x-tcrn-maxUtf8Bytes": 2048
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/strictInstant"
    },
    "tombstone": {
      "type": "boolean"
    },
    "extensions": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/extensionMap"
    }
  }
}
