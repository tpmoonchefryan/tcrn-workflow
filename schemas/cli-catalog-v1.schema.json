{
  "$id": "https://tcrn.dev/schemas/cli-catalog-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCRN CLI Command Catalog V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reasonCode",
    "schemaVersion",
    "commands"
  ],
  "properties": {
    "reasonCode": {
      "const": "CLI_CATALOG_READY"
    },
    "schemaVersion": {
      "const": "tcrn.cli-catalog.v1"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "availability",
          "mutates",
          "flags"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "availability": {
            "enum": [
              "cli",
              "programmatic-only"
            ]
          },
          "mutates": {
            "type": "boolean"
          },
          "flags": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "required",
                "valueKind"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$"
                },
                "required": {
                  "type": "boolean"
                },
                "valueKind": {
                  "enum": [
                    "string",
                    "integer",
                    "boolean",
                    "json",
                    "list",
                    "instant",
                    "enum"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
