{
  "$id": "https://tcrn.dev/schemas/protocol-common-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCRN Protocol Common V1",
  "type": "object",
  "additionalProperties": false,
  "x-tcrn-aos-requirementIds": [
    "AOS-REQ-001",
    "AOS-REQ-002",
    "AOS-REQ-003"
  ],
  "$defs": {
    "canonicalExternalKey": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*$",
      "maxLength": 128
    },
    "extensionMap": {
      "type": "object",
      "maxProperties": 64,
      "additionalProperties": {
        "type": "object",
        "required": [
          "required",
          "value"
        ],
        "properties": {
          "required": {
            "type": "boolean"
          },
          "value": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "additionalProperties": false
      }
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "maxLength": 8192
        },
        {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "maxProperties": 10000,
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,31}:[a-z0-9][a-z0-9._-]{0,127}$",
      "maxLength": 160
    },
    "strictInstant": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,9})?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$"
    }
  }
}
