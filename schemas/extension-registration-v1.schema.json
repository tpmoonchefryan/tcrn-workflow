{
  "$id": "https://tcrn.dev/schemas/extension-registration-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCRN Extension Registration V1",
  "type": "object",
  "additionalProperties": false,
  "x-tcrn-aos-requirementIds": [
    "AOS-REQ-013"
  ],
  "required": [
    "schemaVersion",
    "id",
    "version",
    "requiredByDefault",
    "appliesTo",
    "schemaDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.extension-registration.v1"
    },
    "id": {
      "$ref": "./protocol-common-v1.schema.json#/$defs/stableId"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "requiredByDefault": {
      "type": "boolean"
    },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "work",
          "knowledge",
          "event",
          "context",
          "exchange",
          "receipt"
        ]
      }
    },
    "schemaDigest": {
      "$ref": "./protocol-common-v1.schema.json#/$defs/sha256"
    }
  }
}
