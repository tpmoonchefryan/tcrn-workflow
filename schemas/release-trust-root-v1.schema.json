{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tcrn.dev/workflow/release-trust-root-v1.schema.json",
  "title": "TCRN Workflow Release Trust Root V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "rootVersion",
    "validFrom",
    "validUntil",
    "repository",
    "workflow",
    "minimumSequence",
    "keys"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.release-trust-root.v1"
    },
    "rootVersion": {
      "type": "integer",
      "minimum": 1
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "minimumSequence": {
      "type": "integer",
      "minimum": 1
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keyId",
          "algorithm",
          "publicKeyPem",
          "revokedAt"
        ],
        "properties": {
          "keyId": {
            "type": "string",
            "minLength": 1
          },
          "algorithm": {
            "const": "ed25519"
          },
          "publicKeyPem": {
            "type": "string",
            "minLength": 1
          },
          "revokedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      }
    }
  }
}
