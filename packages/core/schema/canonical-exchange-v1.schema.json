{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcrn.dev/schemas/core/canonical-exchange-v1.schema.json",
  "title": "TCRN Canonical Exchange P7-A",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "exchange",
    "transactionId",
    "sourceWorkspaceId",
    "targetWorkspaceId",
    "idempotencyKey",
    "semanticSubjectDigest",
    "chunks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.canonical-exchange-request.v1"
    },
    "exchange": {
      "$ref": "https://tcrn.dev/schemas/exchange-v1.schema.json"
    },
    "transactionId": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "sourceWorkspaceId": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "targetWorkspaceId": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "idempotencyKey": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
    },
    "semanticSubjectDigest": {
      "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/chunkInput"
      }
    }
  },
  "x-tcrn-deepWellFormedUnicode": true,
  "$defs": {
    "logicalPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*//).+$",
      "x-tcrn-maxUtf8Bytes": 256
    },
    "chunkInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logicalPath",
        "mediaType",
        "contentBase64",
        "semanticDigest"
      ],
      "properties": {
        "logicalPath": {
          "$ref": "#/$defs/logicalPath"
        },
        "mediaType": {
          "enum": [
            "application/json",
            "text/plain; charset=utf-8"
          ]
        },
        "contentBase64": {
          "type": "string",
          "minLength": 4,
          "maxLength": 1398104,
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
        },
        "semanticDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        }
      }
    },
    "chunkRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "index",
        "logicalPath",
        "storedPath",
        "mediaType",
        "size",
        "sha256",
        "semanticDigest"
      ],
      "properties": {
        "id": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "logicalPath": {
          "$ref": "#/$defs/logicalPath"
        },
        "storedPath": {
          "type": "string",
          "pattern": "^chunks/[0-9]{4}-[a-f0-9]{16}\\.chunk$"
        },
        "mediaType": {
          "enum": [
            "application/json",
            "text/plain; charset=utf-8"
          ]
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1048576
        },
        "sha256": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        },
        "semanticDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bundleId",
        "transactionId",
        "sourceWorkspaceId",
        "targetWorkspaceId",
        "idempotencyKey",
        "createdAt",
        "semanticSubjectDigest",
        "exchange",
        "chunks",
        "totalBytes",
        "manifestDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.canonical-exchange-manifest.v1"
        },
        "bundleId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "transactionId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "sourceWorkspaceId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "targetWorkspaceId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "idempotencyKey": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "createdAt": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/strictInstant"
        },
        "semanticSubjectDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        },
        "exchange": {
          "$ref": "https://tcrn.dev/schemas/exchange-v1.schema.json"
        },
        "chunks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/chunkRecord"
          }
        },
        "totalBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8388608
        },
        "manifestDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        }
      },
      "x-tcrn-deepWellFormedUnicode": true
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "transactionId",
        "bundleId",
        "idempotencyKey",
        "manifestDigest",
        "chunkCount",
        "totalBytes",
        "phase",
        "transactionDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.canonical-exchange-transaction.v1"
        },
        "transactionId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "bundleId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "idempotencyKey": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "manifestDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        },
        "chunkCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128
        },
        "totalBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8388608
        },
        "phase": {
          "const": "committed"
        },
        "transactionDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        }
      },
      "x-tcrn-deepWellFormedUnicode": true
    },
    "resume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "transactionId",
        "bundleId",
        "manifestDigest",
        "completedChunkIds",
        "remainingChunkIds",
        "resumeDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.canonical-exchange-resume.v1"
        },
        "transactionId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "bundleId": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
        },
        "manifestDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        },
        "completedChunkIds": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
          }
        },
        "remainingChunkIds": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/stableId"
          }
        },
        "resumeDigest": {
          "$ref": "https://tcrn.dev/schemas/protocol-common-v1.schema.json#/$defs/sha256"
        }
      },
      "x-tcrn-deepWellFormedUnicode": true
    }
  }
}
