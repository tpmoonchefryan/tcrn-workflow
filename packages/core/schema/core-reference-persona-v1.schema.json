{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcrn.dev/schemas/core-reference-persona-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceManifestSha256",
    "profiles",
    "bundleDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.core-reference-persona-bundle.v1"
    },
    "sourceManifestSha256": {
      "const": "9fa68e8f06e73e1d1b4bffb59a059814e683619b1d80234aef82e44f76de7c13"
    },
    "profiles": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "bundleDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "strings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 512
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "profileId",
        "displayName",
        "jobTitle",
        "mission",
        "authorityBoundary",
        "contactWhen",
        "requiredInputs",
        "deliverables",
        "refusals",
        "successCriteria",
        "collaborationRelationships",
        "profileDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.core-reference-persona.v1"
        },
        "profileId": {
          "type": "string",
          "pattern": "^profile:tcrn-[a-z]+-v1$"
        },
        "displayName": {
          "enum": [
            "Arturo",
            "Mara",
            "Minerva",
            "Ilya",
            "Verity",
            "Sable",
            "Janus",
            "Mneme"
          ]
        },
        "jobTitle": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "mission": {
          "type": "string",
          "minLength": 10,
          "maxLength": 512
        },
        "authorityBoundary": {
          "type": "string",
          "minLength": 10,
          "maxLength": 512
        },
        "contactWhen": {
          "type": "string",
          "minLength": 10,
          "maxLength": 512
        },
        "requiredInputs": {
          "$ref": "#/$defs/strings"
        },
        "deliverables": {
          "$ref": "#/$defs/strings"
        },
        "refusals": {
          "$ref": "#/$defs/strings"
        },
        "successCriteria": {
          "$ref": "#/$defs/strings"
        },
        "collaborationRelationships": {
          "$ref": "#/$defs/strings"
        },
        "profileDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
