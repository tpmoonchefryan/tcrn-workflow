{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcrn.dev/schemas/artifact-lifecycle-v1.schema.json",
  "title": "TCRN Artifact Lifecycle V1 Record",
  "x-tcrn-storageLimits": {
    "maximumSourceBytes": 1048576,
    "maximumStoredBytes": 16777216,
    "maximumArchiveBytes": 33554432,
    "maximumEntries": 1024,
    "maximumLogicalBytes": 4294967296,
    "maximumArchiveGenerations": 16,
    "maximumArchiveFilesPerGeneration": 1,
    "maximumArchiveStoredBytes": 33554432
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "state",
    "reference",
    "byteSize",
    "sha256",
    "createdAt",
    "eventHighWaterDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.artifact-record.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^artifact:[a-f0-9]{24}$"
    },
    "kind": {
      "enum": [
        "artifact",
        "terminal-state",
        "decision",
        "gate",
        "acceptance",
        "evidence-reference",
        "receipt",
        "cache"
      ]
    },
    "state": {
      "enum": [
        "active",
        "terminal"
      ]
    },
    "reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "byteSize": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1073741824
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,9})?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$"
    },
    "eventHighWaterDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "enum": [
              "terminal-state",
              "decision",
              "gate",
              "acceptance"
            ]
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "state": {
            "const": "terminal"
          }
        }
      }
    }
  ]
}
