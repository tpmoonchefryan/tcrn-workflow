{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcrn.dev/schemas/workspace-snapshot-manifest-v1.schema.json",
  "title": "TCRN workspace snapshot manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workspaceId",
    "version",
    "headEventHash",
    "validate",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "const": "tcrn.workspace-snapshot-manifest.v1"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^workspace:[a-f0-9]{24}$"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "headEventHash": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "validate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace",
        "knowledge"
      ],
      "properties": {
        "workspace": {
          "const": "valid"
        },
        "knowledge": {
          "enum": [
            "valid",
            "absent"
          ]
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\\\]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
