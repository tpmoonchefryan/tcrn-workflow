{
  "$id": "https://tcrn.dev/schemas/knowledge-core-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCRN File-Native Knowledge Core V1",
  "oneOf": [
    {
      "$ref": "#/$defs/storeMarker"
    },
    {
      "$ref": "#/$defs/metadata"
    }
  ],
  "$defs": {
    "strictInstant": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,9})?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,31}:[A-Za-z0-9._:-]{1,128}$",
      "maxLength": 161
    },
    "sortedStringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "storeMarker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "workspaceId",
        "eventHighWaterDigest",
        "version",
        "disposable",
        "authority"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.knowledge-store.v1"
        },
        "workspaceId": {
          "type": "string",
          "pattern": "^workspace:[a-f0-9]{24}$"
        },
        "eventHighWaterDigest": {
          "$ref": "#/$defs/digest"
        },
        "version": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "disposable": {
          "const": true
        },
        "authority": {
          "const": "metadata-index-authority-body-separate"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "id",
        "externalKey",
        "scope",
        "projectId",
        "roleScopes",
        "category",
        "kind",
        "tags",
        "subject",
        "summary",
        "snippet",
        "sourceReferences",
        "sourceDigest",
        "linkedWorkIds",
        "linkedDecisionIds",
        "linkedGateIds",
        "linkedEvidenceIds",
        "lifecycle",
        "retrievalDisposition",
        "promotionState",
        "freshnessState",
        "lastVerified",
        "stalenessPolicy",
        "redactionDisposition",
        "exportDisposition",
        "authority",
        "sourceProvenance",
        "bodySha256",
        "bodyBytes",
        "revision",
        "updatedAt",
        "extensions"
      ],
      "properties": {
        "schemaVersion": {
          "const": "tcrn.knowledge-unit-metadata.v1"
        },
        "id": {
          "type": "string",
          "pattern": "^knowledge:[a-f0-9]{24}$"
        },
        "externalKey": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]{0,127}$"
        },
        "scope": {
          "enum": [
            "workspace",
            "project",
            "role"
          ]
        },
        "projectId": {
          "anyOf": [
            {
              "$ref": "#/$defs/stableId"
            },
            {
              "type": "null"
            }
          ]
        },
        "roleScopes": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,63}$"
          }
        },
        "category": {
          "enum": [
            "architecture",
            "domain",
            "implementation",
            "standards",
            "testing",
            "workflow",
            "decision",
            "evidence"
          ]
        },
        "kind": {
          "enum": [
            "fact",
            "guide",
            "decision",
            "reference",
            "summary"
          ]
        },
        "tags": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
          }
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "summary": {
          "type": "string",
          "maxLength": 2048
        },
        "snippet": {
          "type": "string",
          "maxLength": 512
        },
        "sourceReferences": {
          "allOf": [
            {
              "$ref": "#/$defs/sortedStringArray"
            },
            {
              "type": "array",
              "maxItems": 16
            }
          ]
        },
        "sourceDigest": {
          "$ref": "#/$defs/digest"
        },
        "linkedWorkIds": {
          "allOf": [
            {
              "$ref": "#/$defs/sortedStringArray"
            },
            {
              "type": "array",
              "maxItems": 64
            }
          ]
        },
        "linkedDecisionIds": {
          "allOf": [
            {
              "$ref": "#/$defs/sortedStringArray"
            },
            {
              "type": "array",
              "maxItems": 64
            }
          ]
        },
        "linkedGateIds": {
          "allOf": [
            {
              "$ref": "#/$defs/sortedStringArray"
            },
            {
              "type": "array",
              "maxItems": 64
            }
          ]
        },
        "linkedEvidenceIds": {
          "allOf": [
            {
              "$ref": "#/$defs/sortedStringArray"
            },
            {
              "type": "array",
              "maxItems": 64
            }
          ]
        },
        "lifecycle": {
          "enum": [
            "candidate",
            "active",
            "retired"
          ]
        },
        "retrievalDisposition": {
          "enum": [
            "default",
            "explicit-only",
            "excluded"
          ]
        },
        "promotionState": {
          "enum": [
            "candidate",
            "promoted",
            "rejected"
          ]
        },
        "freshnessState": {
          "enum": [
            "fresh",
            "stale",
            "unknown"
          ]
        },
        "lastVerified": {
          "anyOf": [
            {
              "$ref": "#/$defs/strictInstant"
            },
            {
              "type": "null"
            }
          ]
        },
        "stalenessPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "maximumAgeDays",
            "unknownDisposition"
          ],
          "properties": {
            "maximumAgeDays": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3650
            },
            "unknownDisposition": {
              "const": "fail-closed"
            }
          }
        },
        "redactionDisposition": {
          "const": "focused-reference-redaction-v1"
        },
        "exportDisposition": {
          "enum": [
            "metadata-only",
            "excluded"
          ]
        },
        "authority": {
          "const": "workspace-knowledge-metadata"
        },
        "sourceProvenance": {
          "const": "explicit-current-source-reference"
        },
        "bodySha256": {
          "$ref": "#/$defs/digest"
        },
        "bodyBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8192
        },
        "revision": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "updatedAt": {
          "$ref": "#/$defs/strictInstant"
        },
        "extensions": {
          "type": "object",
          "maxProperties": 0
        }
      }
    }
  }
}
